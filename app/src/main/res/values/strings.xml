    <!-- Settings screen -->
    <string name="settings_title">Settings</string>
    <string name="cd_open_settings">Open settings</string>
    <string name="settings_section_appearance">Appearance</string>
    <string name="settings_dynamic_color_title">Use system wallpaper colors</string>
    <string name="settings_dynamic_color_subtitle">Override the FaceMesh brand palette with Material You colors derived from your current wallpaper.</string>
    <string name="settings_dynamic_color_unavailable">Requires Android 12 or newer.</string>

    <!-- Settings: Pipeline tuning sliders -->
    <string name="settings_section_pipeline">Pipeline tuning</string>
    <string name="settings_pipeline_section_caption">Override the manifest values for cluster tightness and match strictness. Reset returns each value to the manifest default.</string>
    <string name="settings_dbscan_eps_title">Cluster tightness</string>
    <string name="settings_dbscan_eps_subtitle">Lower values produce tighter clusters (more "same person" splits). Higher values merge faces more eagerly.</string>
    <string name="settings_match_threshold_title">Match strictness</string>
    <string name="settings_match_threshold_subtitle">Lower values keep more photos (recall up). Higher values keep only stronger matches (precision up).</string>
    <string name="settings_value_decimal">%1$.2f</string>
    <string name="settings_value_with_source">%1$.2f (%2$s)</string>
    <string name="settings_source_user">modified</string>
    <string name="settings_source_manifest">manifest</string>
    <string name="settings_source_default">default</string>

    <!-- Settings: Face Detection Model section -->
    <string name="settings_section_detector">Face detection model</string>
    <string name="settings_detector_caption">Switch to full-range if photos with small or off-axis faces aren\'t clustering correctly. Change takes effect on the next Clusterify or Filter run.</string>
    <string name="settings_detector_short_range_label">Close-up</string>
    <string name="settings_detector_short_range_subtitle">BlazeFace short-range, 128 x 128 input, ~230 KB. Best on selfie-distance frontal faces filling 30-80%% of the frame. Lighter and faster, but misses many small or off-axis faces.</string>
    <string name="settings_detector_full_range_label">Group / distant</string>
    <string name="settings_detector_full_range_subtitle">BlazeFace full-range, 192 x 192 input, ~1.1 MB. Default. Roughly 20%% slower per image, but reliably recovers small and off-axis faces in group photos that the close-up model misses.</string>
</resources>
